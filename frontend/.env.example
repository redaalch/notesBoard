# ── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_NOTEBOOK_ANALYTICS=true

# ── API & Collaboration ─────────────────────────────────────────────────────
# Defaults to window.location.origin/api when unset (works for same-origin deploys).
# VITE_API_BASE_URL=http://localhost:5001

# WebSocket server for real-time collaborative editing.
# VITE_COLLAB_SERVER_URL=ws://localhost:6001
# VITE_COLLAB_PATH=/collab

# ── Public Notebook URLs ────────────────────────────────────────────────────
# Base URL for published notebook pages (used in share dialogs).
# VITE_PUBLIC_NOTEBOOK_BASE_URL=http://localhost:5173/published
