# ── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/notes_db
MONGO_DB=notes_db

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── Frontend URLs ────────────────────────────────────────────────────────────
# Required in production — used for CORS, share links, invite links, and note
# collaboration URLs. In development, localhost:5173 is used as a fallback.
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_HOST=

# ── Collaboration WebSocket ──────────────────────────────────────────────────
COLLAB_WS_URL=ws://localhost:6001

# ── Rate Limiting (Upstash Redis) — required in production ──────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email (Nodemailer) ──────────────────────────────────────────────────────
MAILER_TO_GO_URL=
MAIL_FROM_ADDRESS=NotesBoard <no-reply@yourdomain.com>
MAIL_FROM_DOMAIN=yourdomain.com
PASSWORD_RESET_URL=http://localhost:5173/reset-password

# ── AI Features ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
EMBEDDING_PROVIDER=groq
EMBEDDING_DIMENSIONS=1536

# ── Optional: Override specific frontend link URLs ──────────────────────────
# These take priority over FRONTEND_ORIGIN when building share/invite/collab links.
# CLIENT_APP_URL=
# NOTEBOOK_SHARE_URL=
# NOTEBOOK_INVITE_URL=
# NOTE_COLLABORATION_URL=
# FRONTEND_URL=
